# Optional — Maps Embed API for DineOut (https://console.cloud.google.com/google/maps-apis).
# Without a key, DineOut uses a generic Google Maps embed URL (fine for local demo).
# VITE_GOOGLE_MAPS_API_KEY=

# GitHub Actions secret — password used by staticrypt to encrypt the deployed HTML.
# Set this in: GitHub repo → Settings → Secrets and variables → Actions → New repository secret
# Name: SITE_PASSWORD  Value: <your password>
# Not needed locally (encryption only runs in CI).
